flex
	display: inline-flex
	flex-direction: row
	& > *
		flex: 1 1

[upwards]
	flex-direction: column-reverse
[downwards]
	flex-direction: column
[leftwards]
	flex-direction: row-reverse
[rightwards]
	flex-direction: row

[no-grow]
	flex-grow: 0
[no-shrink]
	flex-shrink: 0
[no-flex]
	flex: 0 0

@for $b from 1 to $DEPTH
	@for $a from 1 to $b
		@include percentage(flex)
