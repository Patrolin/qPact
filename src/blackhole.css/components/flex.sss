flex
	display: inline-flex
	flex-direction: row
	& > *
		flex: 1 1

[upwards]
	@include flex-upwards
[downwards]
	@include flex-downwards
[leftwards]
	@include flex-leftwards
[rightwards]
	@include flex-rightwards

[no-grow]
	flex-grow: 0
[no-shrink]
	flex-shrink: 0
[no-flex]
	flex: 0 0

@for $b from 1 to $DEPTH
	[flex="$b"]
		flex: $b
	@for $a from 1 to $b
		[flex="$a/$b"]
			flex: resolve($a/$b)
