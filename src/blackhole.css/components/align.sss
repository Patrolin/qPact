align
	display: inline-flex
	justify-content: center
	align-items: center
	text-align: center
	& > *
		flex: 0 0
	&:not([upwards], [leftwards], [rightwards])
		@include flex-downwards

/* TODO: add align spacing
*/

[text-align='left']
	text-align: left
[text-align='center']
	text-align: center
[text-align='right']
	text-align: right
[text-align='justify']
	text-align: justify
